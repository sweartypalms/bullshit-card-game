<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title><%= profileUsername %>'s Profile</title>
  <%- include('shared/head') %>
</head>

<body class="<%= isPopup ? 'profile-popup-body' : '' %>">
  <div id="container" class="<%= isPopup ? 'profile-popup-container' : '' %>">
    <% if (!isPopup) { %>
      <%- include('shared/menu') %>
    <% } %>

    <section class="profile-shell <%= isPopup ? 'profile-shell-popup' : '' %>">
      <div class="profile-hero">
        <div>
          <p class="profile-kicker"><%= isPopup ? 'Quick Profile' : 'Player Profile' %></p>
          <h1><%= profileUsername %></h1>
          <p class="profile-subtitle">
            <% if (typeof notFound !== 'undefined' && notFound) { %>
              We couldn't find a profile for this player.
            <% } else if (isGuest && !isPopup) { %>
              Guest stats are temporary. Register to keep these benefits long-term.
            <% } else { %>
              <%= isPopup ? 'A quick look at this player\'s record.' : 'Your running record across completed and abandoned games.' %>
            <% } %>
          </p>
        </div>
        <div class="profile-total-card">
          <span class="profile-total-label">Tracked Games</span>
          <strong><%= totalTrackedGames %></strong>
        </div>
      </div>

      <div class="profile-grid">
        <section class="profile-card stat-card wins">
          <span class="stat-label">Wins</span>
          <strong><%= stats.wins %></strong>
        </section>
        <section class="profile-card stat-card losses">
          <span class="stat-label">Losses</span>
          <strong><%= stats.losses %></strong>
        </section>
        <section class="profile-card stat-card abandoned">
          <span class="stat-label">Abandoned Games</span>
          <strong><%= stats.abandoned_games %></strong>
        </section>
      </div>

      <section class="profile-card profile-chart-card">
        <div class="chart-header">
          <div>
            <h2>Stats Chart</h2>
            <p>Quick view of how this player's games break down.</p>
          </div>
        </div>

        <% if (chartSegments.length) { %>
          <div class="profile-chart-bar" aria-label="Profile stats chart">
            <% chartSegments.forEach(function(segment) { %>
              <span
                class="chart-segment <%= segment.className %>"
                style="width: <%= segment.percent %>%"
                title="<%= segment.label %>: <%= segment.value %>">
              </span>
            <% }); %>
          </div>

          <ul class="chart-legend">
            <% chartSegments.forEach(function(segment) { %>
              <li>
                <span class="legend-dot <%= segment.className %>"></span>
                <span><%= segment.label %></span>
                <strong><%= segment.value %></strong>
              </li>
            <% }); %>
          </ul>
        <% } else { %>
          <p class="chart-empty">No tracked games yet. Once this player completes games, their chart will appear here.</p>
        <% } %>
      </section>
    </section>
  </div>
</body>

</html>
